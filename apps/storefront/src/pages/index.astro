---
import { buildSiteModel } from "@restaurant-platform/site-generator";

import {
  formatBusinessHours,
  formatCurrency,
  formatLabel,
} from "../presentation.js";

const restaurantDirectory = import.meta.env.DEMO_RESTAURANT_DIRECTORY;
const model = await buildSiteModel(restaurantDirectory);
const { restaurant, menu } = model;
const menuSections = [...menu.sections].sort(
  (left, right) => left.displayOrder - right.displayOrder,
);
const socialLinks = Object.entries(restaurant.socialLinks ?? {});
const phoneHref = `tel:${model.contact.phone.replace(/[^\d+]/g, "")}`;
const secondaryColor = model.branding.colors.secondary ?? "#fff7ed";
const accentColor = model.branding.colors.accent ?? model.branding.colors.primary;
---

<!doctype html>
<html
  lang="en"
  style={`--brand-primary: ${model.branding.colors.primary}; --brand-secondary: ${secondaryColor}; --brand-accent: ${accentColor};`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={model.metadata.pageDescription} />
    <title>{model.metadata.pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container hero">
        <p class="eyebrow">Welcome to</p>
        <h1>{restaurant.name}</h1>
        {restaurant.tagline && <p class="tagline">{restaurant.tagline}</p>}
        {restaurant.description && (
          <p class="introduction">{restaurant.description}</p>
        )}
        {restaurant.orderingLink && (
          <a class="primary-action" href={restaurant.orderingLink}>
            Order online from {restaurant.name}
          </a>
        )}
      </div>
    </header>

    <main>
      <section class="details-section" aria-labelledby="visit-heading">
        <div class="container details-grid">
          <div>
            <h2 id="visit-heading">Visit and contact us</h2>
            <address>
              <span>{model.contact.address.street}</span>
              {model.contact.address.street2 && (
                <span>{model.contact.address.street2}</span>
              )}
              <span>
                {model.contact.address.city}, {model.contact.address.region}{" "}
                {model.contact.address.postalCode}
              </span>
              <span>{model.contact.address.country}</span>
            </address>
            <ul class="contact-list">
              <li>
                <a href={phoneHref}>
                  Call {restaurant.name} at {model.contact.phone}
                </a>
              </li>
              {model.contact.email && (
                <li>
                  <a href={`mailto:${model.contact.email}`}>
                    Email {restaurant.name} at {model.contact.email}
                  </a>
                </li>
              )}
            </ul>
            {socialLinks.length > 0 && (
              <nav aria-label={`${restaurant.name} social links`}>
                <h3>Follow us</h3>
                <ul class="social-list">
                  {socialLinks.map(([network, url]) => (
                    <li>
                      <a href={url}>
                        {restaurant.name} on {formatLabel(network)}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            )}
          </div>

          <div>
            <h2>Business hours</h2>
            <dl class="hours-list">
              {restaurant.businessHours.map((entry) => (
                <div>
                  <dt>{formatLabel(entry.day)}</dt>
                  <dd>{formatBusinessHours(entry)}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </section>

      <section class="menu-section" aria-labelledby="menu-heading">
        <div class="container">
          <header class="section-heading">
            <p class="eyebrow">What we serve</p>
            <h2 id="menu-heading">{menu.name}</h2>
            {menu.description && <p>{menu.description}</p>}
          </header>

          <div class="menu-sections">
            {menuSections.map((section) => (
              <section class="menu-category" aria-labelledby={`section-${section.id}`}>
                <header>
                  <h3 id={`section-${section.id}`}>{section.name}</h3>
                  {section.description && <p>{section.description}</p>}
                </header>

                <ul class="menu-items">
                  {section.items.map((item) => (
                    <li
                      class:list={[
                        "menu-item",
                        { unavailable: item.availability === "unavailable" },
                      ]}
                    >
                      <article>
                        <header class="item-heading">
                          <h4>{item.name}</h4>
                          <div class="item-states">
                            {item.featured && <span class="badge">Featured</span>}
                            {item.availability === "unavailable" && (
                              <span class="badge unavailable-badge">
                                Currently unavailable
                              </span>
                            )}
                          </div>
                        </header>

                        {item.description && <p>{item.description}</p>}

                        <ul class="price-list" aria-label={`${item.name} prices`}>
                          {item.prices.map((price) => (
                            <li>
                              {"name" in price && (
                                <span>{formatLabel(price.name)}</span>
                              )}
                              <strong>
                                {formatCurrency(price.amount, menu.currency)}
                              </strong>
                            </li>
                          ))}
                        </ul>

                        {item.dietaryTags && (
                          <ul
                            class="dietary-list"
                            aria-label={`${item.name} dietary information`}
                          >
                            {item.dietaryTags.map((tag) => (
                              <li>{formatLabel(tag)}</li>
                            ))}
                          </ul>
                        )}
                      </article>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="container">
        <p>{restaurant.name}</p>
        <p>
          <a href={phoneHref}>{model.contact.phone}</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    background: var(--brand-secondary);
    color: #251a17;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    line-height: 1.6;
  }

  :global(body) {
    margin: 0;
  }

  :global(a) {
    color: var(--brand-primary);
    text-underline-offset: 0.18em;
  }

  :global(a:focus-visible) {
    outline: 3px solid var(--brand-accent);
    outline-offset: 3px;
  }

  .container {
    width: min(70rem, calc(100% - 2rem));
    margin-inline: auto;
  }

  .site-header {
    padding-block: clamp(4rem, 10vw, 8rem);
    background: var(--brand-primary);
    color: white;
  }

  .hero {
    max-width: 52rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  h4,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0.5rem;
    font-size: clamp(2.75rem, 8vw, 5.5rem);
    line-height: 1;
  }

  h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1.15;
  }

  .tagline {
    margin-bottom: 1rem;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
  }

  .introduction {
    max-width: 45rem;
    font-size: 1.1rem;
  }

  .primary-action {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    border: 2px solid white;
    border-radius: 0.25rem;
    color: white;
    font-weight: 700;
  }

  .details-section,
  .menu-section {
    padding-block: clamp(3rem, 7vw, 5rem);
  }

  .details-grid {
    display: grid;
    gap: 3rem;
  }

  address span {
    display: block;
  }

  .contact-list,
  .social-list,
  .menu-items,
  .price-list,
  .dietary-list {
    padding: 0;
    list-style: none;
  }

  .hours-list {
    margin: 0;
  }

  .hours-list div {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1rem;
    padding-block: 0.35rem;
    border-bottom: 1px solid color-mix(in srgb, var(--brand-primary), transparent 75%);
  }

  .hours-list dt {
    font-weight: 700;
  }

  .hours-list dd {
    margin: 0;
  }

  .menu-section {
    background: white;
  }

  .section-heading {
    max-width: 44rem;
    margin-bottom: 3rem;
  }

  .menu-sections {
    display: grid;
    gap: 3rem;
  }

  .menu-category > header {
    border-bottom: 3px solid var(--brand-primary);
  }

  .menu-items {
    display: grid;
    gap: 1rem;
  }

  .menu-item {
    padding-block: 1.5rem;
    border-bottom: 1px solid #ded6d2;
  }

  .menu-item.unavailable {
    opacity: 0.65;
  }

  .item-heading,
  .price-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .item-heading h4 {
    margin-bottom: 0.25rem;
    font-size: 1.25rem;
  }

  .item-states,
  .dietary-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .badge,
  .dietary-list li {
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    background: var(--brand-secondary);
    color: #251a17;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .unavailable-badge {
    background: #ece8e6;
  }

  .price-list {
    max-width: 18rem;
  }

  .dietary-list {
    margin-bottom: 0;
  }

  footer {
    padding-block: 2rem;
    background: #251a17;
    color: white;
  }

  footer p {
    margin-bottom: 0.25rem;
  }

  footer a {
    color: white;
  }

  @media (min-width: 48rem) {
    .details-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
