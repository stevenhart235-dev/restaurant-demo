---
import { buildSiteModel } from "@restaurant-platform/site-generator";
import { resolveTheme } from "@restaurant-platform/themes";

const restaurantDirectory = import.meta.env.DEMO_RESTAURANT_DIRECTORY;
const model = await buildSiteModel(restaurantDirectory);
const theme = resolveTheme(model.branding.theme);
const ThemeComponent = theme.component;
---

<ThemeComponent model={model} presentation={theme.presentation} />
